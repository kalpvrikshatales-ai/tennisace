# Tennis data API key from https://api.github.com/repos/SleekByte-Studio/tennis-explorer/contents
TENNIS_API_KEY=your_key_here

# Supabase database credentials
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Web Push Notifications (VAPID keys)
VAPID_PUBLIC_KEY=your_public_key
VAPID_PRIVATE_KEY=your_private_key
VAPID_EMAIL=mailto:your-email@example.com

# Optional: Redis caching
# Standard Redis URL (e.g., redis://localhost:6379)
REDIS_URL=redis://localhost:6379
# Or use Upstash (https://upstash.com)
# UPSTASH_REDIS_URL=https://default:<password>@<host>:<port>

# Optional: Rate limiting (disable for development if needed)
RATE_LIMIT_ENABLED=true
